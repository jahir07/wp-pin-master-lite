<?xml version="1.0"?>
<ruleset name="WP Pin Master">
	<description>WordPress Coding Standards for WP Pin Master.</description>

	<file>wp-pin-master.php</file>
	<file>uninstall.php</file>
	<file>includes</file>

	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<arg value="sp"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<config name="minimum_wp_version" value="6.0"/>
	<config name="testVersion" value="7.4-"/>

	<rule ref="WordPress">
		<!-- Short array syntax is fine; project predates alignment rules on build files. -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="wp-pin-master"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="pin_master"/>
				<element value="Pin_Master"/>
				<element value="PIN_MASTER"/>
				<element value="wp_pin_master"/>
			</property>
		</properties>
	</rule>
</ruleset>
